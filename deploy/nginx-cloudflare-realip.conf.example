# Cloudflare + Nginx 真实 IP 示例
# 说明：
# 1. 请把下面的 <Cloudflare ... CIDR> 替换成 Cloudflare 官方公布的全部 IPv4 / IPv6 网段
# 2. 推荐把本文件放进 http {} 或 server {} 级别的共享 include 中
# 3. 应用层现在已经会优先读取 CF-Connecting-IP，但 nginx 仍然需要正确回源真实 IP

# 只信任来自 Cloudflare 的连接
set_real_ip_from <Cloudflare IPv4 CIDR>;
set_real_ip_from <Cloudflare IPv6 CIDR>;

# 让 nginx 把真实访客 IP 还原到 remote_addr
real_ip_header CF-Connecting-IP;
real_ip_recursive on;

# 回源给应用时继续带上真实来源
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;

# 如需单独收紧后台，可在 /admin/cards 相关 location 上继续叠加：
# allow <你的固定出口 IP>;
# deny all;
