# Fragment 接口配置
# fragment.com 生成的 hash 值
ResHash=

# fragment.com 生成的 cookie 值
# 可从浏览器开发者工具里 Copy as cURL 提取 cookie 请求头
ResCookie=

# fragment.com 请求里的 dh 值
# 可从 Copy as cURL 的 data-raw 中提取
ResDH=


# TonConnect v2 钱包信息
# 在 fragment.com/stars/buy 页面连接钱包后，从控制台提取：
# JSON.stringify(Aj.globalState.tonConnectUI.wallet.account)
TonAccount=

# JSON.stringify(Aj.globalState.tonConnectUI.wallet.device)
TonDevice=


# 付款钱包助记词，用空格分隔
WalletMnemonic=

# 钱包版本
# 新版 Tonkeeper 一般用 V5R1Final
# 老钱包才可能是 V4R2
# 不建议留空，留空时程序会默认按 V4R2 处理
WalletVersion=V5R1Final


# 单次执行模式
# 只有 ListenAddr 留空时，才会按下面配置直接执行一次
OpenType=stars
OpenDuration=3
OpenStars=50
OpenUserName=ciyuancat


# HTTP API / 网站服务模式
# 填了 ListenAddr 就会启动 HTTP 服务，不再按上面的单次模式启动
ListenAddr=:18082
HookToken=replace-with-a-random-secret
AdminToken=replace-with-an-admin-secret
CardStorePath=data/gift_cards.json
RequestTimeoutSeconds=90
QueueWorkers=1
